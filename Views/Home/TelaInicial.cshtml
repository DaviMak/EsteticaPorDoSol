@{
    ViewData["Title"] = "Inicio";
}

<!-- Topo -->
<div style="display:flex; align-items:center; justify-content:space-between; padding: 10px;">
    <button class="btn btn-light">☰</button>
    <img src="/img/logo.png" alt="PDSLogo" style="height:50px;">
    <form method="get" asp-controller="Atendimento" asp-action="BuscarPorPlaca" class="d-flex gap-1">
        <input type="text" name="placa" placeholder="Buscar por placa" class="form-control" />
        <button type="submit" class="btn btn-secondary">🔍</button>
    </form>
</div>

<!-- Botões principais -->
<div class="text-center mt-4">
    <div class="row justify-content-center gap-3">
        <div class="col-4">
            <a asp-controller="Home" asp-action="Entrada" class="btn btn-success w-100 btn-lg">⬅️ Entrada</a>
        </div>
        <div class="col-4">
            <a asp-controller="Atendimento" asp-action="Saida" class="btn btn-danger w-100 btn-lg">Saída ➡️</a>
        </div>
    </div>
</div>