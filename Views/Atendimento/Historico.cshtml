@model List<EsteticaPorDoSol.Models.Atendimento>
@{
    ViewData["Title"] = "Histórico Geral";
}

<h2>Histórico Geral</h2>

@if (!Model.Any())
{
    <p>Nenhum atendimento registrado.</p>
}
else
{
    <table class="table table-bordered">
        <tr>
            <th>Data</th>
            <th>Cliente</th>
            <th>Veículo</th>
            <th>Placa</th>
            <th>Serviços</th>
            <th>Total</th>
            <th>Status</th>
        </tr>
        @foreach (var atendimento in Model)
        {
            <tr>
                <td>@atendimento.dtDataHoraAtendimento.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@atendimento.Cliente?.dsNome</td>
                <td>@atendimento.Veiculo?.dsModelo</td>
                <td>@atendimento.Veiculo?.dsPlaca</td>
                <td>
                    @foreach (var s in atendimento.AtendimentoServicos)
                    {
                        <span>@s.Servico?.dsNomeServico — R$ @s.vlServicoNoMomento.ToString("F2")</span><br />
                    }
                </td>
                <td>R$ @atendimento.vlTotal.ToString("F2")</td>
                <td>
                    <span class="badge @(atendimento.dsStatus == "Aberto" ? "bg-success" : "bg-danger")">
                        @atendimento.dsStatus
                    </span>
                </td>
            </tr>
        }
    </table>
}

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Voltar</a>