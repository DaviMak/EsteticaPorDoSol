@model List<EsteticaPorDoSol.Models.Veiculo>
@{
    ViewData["Title"] = "Selecionar Veículo";
}

<h2>Selecionar Veículo</h2>
<p>Encontramos mais de um veículo. Selecione qual deseja atender:</p>

<table class="table table-bordered">
    <tr>
        <th>Cliente</th>
        <th>Placa</th>
        <th>Modelo</th>
        <th>Cor</th>
        <th></th>
    </tr>
    @foreach (var veiculo in Model)
    {
        <tr>
            <td>@veiculo.Cliente?.dsNome</td>
            <td>@veiculo.dsPlaca</td>
            <td>@veiculo.dsModelo</td>
            <td>@veiculo.dsCor</td>
            <td>
                <a asp-controller="Atendimento" asp-action="NovoAtendimento" 
                   asp-route-idVeiculo="@veiculo.idVeiculo" 
                   class="btn btn-primary btn-sm">Selecionar</a>
            </td>
        </tr>
    }
</table>

<a asp-controller="Home" asp-action="Entrada" class="btn btn-secondary">Voltar</a>