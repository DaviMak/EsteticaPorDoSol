@{
    ViewData["Title"] = "Novo Atendimento";
    var veiculo = ViewBag.Veiculo as EsteticaPorDoSol.Models.Veiculo;
    var servicos = ViewBag.Servicos as List<EsteticaPorDoSol.Models.Servico>;
}

<h2>Novo Atendimento</h2>

<p><strong>Cliente:</strong> @veiculo?.Cliente?.dsNome</p>
<p><strong>Veículo:</strong> @veiculo?.dsModelo — @veiculo?.dsPlaca — @veiculo?.dsCor</p>

<form asp-action="NovoAtendimento" method="post">
    <input type="hidden" name="idVeiculo" value="@veiculo?.idVeiculo" />

    <h5 class="mt-3">Selecione os Serviços:</h5>

    @foreach (var servico in servicos!)
    {
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" 
                name="servicosSelecionados" 
                value="@servico.idServico" 
                id="s@(servico.idServico)"
                onchange="toggleValor(@servico.idServico)" />
            <label class="form-check-label" for="s@(servico.idServico)">
                @servico.dsNomeServico
            </label>
            <input type="number" step="0.01" min="0"
                name="valoresServicos"
                id="v@(servico.idServico)"
                value="@servico.vlServico"
                placeholder="R$: @servico.vlServico.ToString("F2")"
                class="form-control mt-1"
                style="display:none; width:150px;"
                placeholder="Valor (R$)" />
        </div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-success">Registrar Entrada</button>
        <a asp-controller="Home" asp-action="TelaInicial" class="btn btn-secondary">Cancelar</a>
    </div>


    <script>
        function toggleValor(id) {
            var checkbox = document.getElementById('s' + id);
            var input = document.getElementById('v' + id);
            input.style.display = checkbox.checked ? 'block' : 'none';
        }
    </script>
</form>